{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "components/AddFoodClient(1).tsx",
    "components/AddFoodClient(2).tsx",
    "app/add-food/page(1).tsx",
    "app/add-food/page(2).tsx",
    "app/api/openfoodfacts-search/route(1).ts",
    "app/api/openfoodfacts-search/route(2).ts",
    "lib/foodSearchShared(1).ts",
    "lib/foodSearchShared(2).ts"
  ]
}
