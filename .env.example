# העתק לקובץ `.env.local` (לא נכנס ל-git) או הגדר את אותם המפתחות ב-Netlify → Site configuration → Environment variables
# אחרי שינוי ב-Netlify יש לבצע Deploy מחדש כדי שהבילד יכלול את הערכים.

# כניסת מנהלת בלחיצה אחת (בלי חלון קוד) — מתאים למחשב פיתוח / בדיקות
NEXT_PUBLIC_ALLOW_DEV_ADMIN_BYPASS=1

# קוד כניסה לפרודקשן כשה-bypass כבוי (לפחות 4 תווים)
NEXT_PUBLIC_DEV_ADMIN_PIN=1234

# --- AI meal log ---
# OpenAI (מומלץ לפרודקשן): משמש כ-System Message בשרת
# OPENAI_API_KEY=sk-...
# OPENAI_MEAL_MODEL=gpt-4.1-mini
#
# Gemini (Fallback):
# GOOGLE_GENERATIVE_AI_API_KEY=...
