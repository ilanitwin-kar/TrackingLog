# העתק לקובץ `.env.local` (לא נכנס ל-git) או הגדר את אותם המפתחות ב-Netlify → Site configuration → Environment variables
# אחרי שינוי ב-Netlify יש לבצע Deploy מחדש כדי שהבילד יכלול את הערכים.

# כניסת מנהלת בלחיצה אחת (בלי חלון קוד) — מתאים למחשב פיתוח / בדיקות
NEXT_PUBLIC_ALLOW_DEV_ADMIN_BYPASS=1

# הצגת כפתור «כניסת מנהלת» במסכי הכניסה (Netlify)
# NEXT_PUBLIC_SHOW_DEV_ADMIN_BYPASS_UI=1
# אם הכפתור מוצג ואין NEXT_PUBLIC_DEV_ADMIN_PIN (או STAFF_UNLOCK ארוך) — בפרודקשן תתאפשר כניסה בלי הקלדת קוד (נייד).

# קוד כניסה לפרודקשן כשה-bypass כבוי (לפחות 4 תווים)
NEXT_PUBLIC_DEV_ADMIN_PIN=1234

# --- AI meal log ---
# OpenAI (מומלץ לפרודקשן): משמש כ-System Message בשרת
# OPENAI_API_KEY=sk-...
# OPENAI_MEAL_MODEL=gpt-4.1-mini
#
# Gemini (Fallback):
# GOOGLE_GENERATIVE_AI_API_KEY=...

# --- Firebase (Cloud memory / sync) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=...
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=...
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=...
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
# NEXT_PUBLIC_FIREBASE_APP_ID=...
