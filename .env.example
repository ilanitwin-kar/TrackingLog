# העתק לקובץ `.env.local` (לא נכנס ל-git) או הגדר את אותם המפתחות ב-Vercel → Project → Settings → Environment Variables
# אחרי שינוי משתני סביבה ב-Vercel יש Deploy מחדש כדי שהבילד יכלול את הערכים.

# כניסת מנהלת בלחיצה אחת (בלי חלון קוד) — מתאים למחשב פיתוח / בדיקות
NEXT_PUBLIC_ALLOW_DEV_ADMIN_BYPASS=1

# הצגת כפתור «כניסת מנהלת» במסכי הכניסה (פרודקשן — רק אם מוגדר במפורש)
# NEXT_PUBLIC_SHOW_DEV_ADMIN_BYPASS_UI=1
# אם הכפתור מוצג ואין NEXT_PUBLIC_DEV_ADMIN_PIN (או STAFF_UNLOCK ארוך) — בפרודקשן תתאפשר כניסה בלי הקלדת קוד (נייד).

# קוד כניסה לפרודקשן כשה-bypass כבוי (לפחות 4 תווים)
NEXT_PUBLIC_DEV_ADMIN_PIN=1234

# --- AI meal log ---
# OpenAI (מומלץ לפרודקשן): משמש כ-System Message בשרת
# OPENAI_API_KEY=sk-...
# OPENAI_MEAL_MODEL=gpt-4.1-mini
#
# Gemini (Fallback):
# GOOGLE_GENERATIVE_AI_API_KEY=...
# GEMINI_ASSISTANT_MODEL=gemini-1.5-pro

# --- AI assistant / menu builder ---
# OPENAI_ASSISTANT_MODEL=gpt-4.1-mini

# --- Weather (optional) ---
# OPENWEATHER_API_KEY=...

# --- Firebase (Cloud memory / sync) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=...
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=...
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=...
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
# NEXT_PUBLIC_FIREBASE_APP_ID=...
# אם יצרת Firestore עם Database ID שאינו (default) (למשל "tracking-log"):
# NEXT_PUBLIC_FIREBASE_FIRESTORE_DB_ID=tracking-log
#
# איפוס סיסמה במייל: בקונסולת Firebase → Authentication → Sign-in method → הפעל Email/Password.
# ב-Authentication → Settings → Authorized domains: הוסיפי את דומיין האתר (כולל localhost לפיתוח).

# --- Resend (מיילי ברוכים הבאים + איפוס סיסמה ממותגים) ---
# RESEND_API_KEY=re_...
# כתובת שולח מאומתת ב-Resend (בדיקות: onboarding@resend.dev; בפרודקשן: דומיין משלך)
# RESEND_FROM_ADDRESS=onboarding@resend.dev
#
# מייל איפוס / דף ניהול — Firebase Admin (Service Account):
# אופציה א׳ — JSON בשורה אחת (בלי שבירות שורה בתוך המפתח):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# אופציה ב׳ — נתיב לקובץ שהורדת (מומלץ אם .env שובר את ה-JSON):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# (או GOOGLE_APPLICATION_CREDENTIALS=תואם כמו למעלה)
# Firebase Console → Project settings → Service accounts → Generate new private key

# --- USDA FoodData Central (חיפוש מזון בדף «הוסף מזון») ---
# https://fdc.nal.usda.gov/api-key-signup
# USDA_API_KEY=
